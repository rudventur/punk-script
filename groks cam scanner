import 'package:video_player/video_player.dart';
import 'package:model_viewer_plus/model_viewer_plus.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';

late List<CameraDescription> cameras;

// ====================== STATE ======================
final qualityProvider = StateProvider<Quality>((ref) => Quality.low);
final scanModeProvider = StateProvider<ScanMode>((ref) => ScanMode.photo);
final imagesProvider = StateProvider<List<File>>((ref) => []);
final stepsProvider = StateProvider<int>((ref) => 0);
final isScanningProvider = StateProvider<bool>((ref) => false);
final modelFileProvider = StateProvider<File?>((ref) => null);

enum Quality { low, medium, high } // low = "Just Structure" for metro etc.
enum ScanMode { photo, video }

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  cameras = await availableCameras();
  runApp(const ProviderScope(child: MyApp()));
}

