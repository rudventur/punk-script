// ====================== CAMERA + SCAN SCREEN ======================
class CameraScreen extends ConsumerStatefulWidget {
  const CameraScreen({super.key});
  @override
  ConsumerState<CameraScreen> createState() => _CameraScreenState();
}

class _CameraScreenState extends ConsumerState<CameraScreen> {
  CameraController? controller;
  VideoPlayerController? videoController;
  bool isRecording = false;
  Timer? frameTimer;
  StreamSubscription<PedometerData>? pedoSub;
  int totalSteps = 0;
  List<File> capturedImages = [];
  File? recordedVideo;

  @override
  void initState() {
    super.initState();
    _initCamera();
    _startPedometer();
  }

  Future<void> _initCamera() async {
    await Permission.camera.request();
    await Permission.storage.request();
    controller = CameraController(cameras[0], ResolutionPreset.high, enableAudio: false);
    await controller!.initialize();
    setState(() {});
  }

  void _startPedometer() {
    pedoSub = Pedometer.stepCountStream.listen((event) {
      totalSteps = event.steps;
      ref.read(stepsProvider.notifier).state = totalSteps;
    });
  }

  Future<void> capturePhoto() async {
    if (controller == null || !controller!.value.isInitialized) return;
    final file = File('${(await getTemporaryDirectory()).path}/img_${DateTime.now().millisecondsSinceEpoch}.jpg');
    await controller!.takePicture().then((XFile xfile) async {
      await xfile.saveTo(file.path);
      capturedImages.add(file);
      ref.read(imagesProvider.notifier).state = List.from(capturedImages);
      setState(() {});
    });
  }

  Future<void> startVideo() async {
    if (controller == null) return;
    final file = File('${(await getTemporaryDirectory()).path}/video_${DateTime.now().millisecondsSinceEpoch}.mp4');
    await controller!.startVideoRecording();
    isRecording = true;
    setState(() {});

    // Auto-extract frames every 500ms (video mode)
    frameTimer = Timer.periodic(const Duration(milliseconds: 500), (timer) async {
      if (!isRecording) return;
      final imgFile = File('${(await getTemporaryDirectory()).path}/frame_${DateTime.now().millisecondsSinceEpoch}.jpg');
      await controller!.takePicture().then((xfile) async {
        await xfile.saveTo(imgFile.path);
        capturedImages.add(imgFile);
        ref.read(imagesProvider.notifier).state = List.from(capturedImages);
      });
    });
  }

  Future<void> stopVideo() async {
    if (!isRecording) return;
    final xfile = await controller!.stopVideoRecording();
    recordedVideo = File(xfile.path);
    frameTimer?.cancel();
    isRecording = false;
    setState(() {});
  }

  @override
  void dispose() {
    controller?.dispose();
    videoController?.dispose();
    pedoSub?.cancel();
    frameTimer?.cancel();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final quality = ref.watch(qualityProvider);
    final steps = ref.watch(stepsProvider);
    final images = ref.watch(imagesProvider);

    if (controller == null || !controller!.value.isInitialized) {
      return const Scaffold(body: Center(child: CircularProgressIndicator()));
    }

    return Scaffold(
      appBar: AppBar(
        title: Text('${quality.name.toUpperCase()} • ${images.length} pics • $steps steps'),
        actions: [
          IconButton(
            icon: const Icon(Icons.check),
            onPressed: images.isNotEmpty || recordedVideo != null
                ? () => _processAndShowModel(context, quality)
                : null,
          )
        ],
      ),
      body: Stack(
        children: [
          CameraPreview(controller!),
          // Overlay instructions
          Positioned(
            top: 20,
            left: 20,
            right: 20,
            child: Container(
              padding: const EdgeInsets.all(12),
              decoration: BoxDecoration(color: Colors.black54, borderRadius: BorderRadius.circular(12)),
              child: Text(
                'Move slowly around object\nWalk for metro routes → step counter tracks distance',
                textAlign: TextAlign.center,
                style: const TextStyle(color: Colors.white, fontSize: 16),
              ),
            ),
          ),
          // Bottom controls
          Positioned(
            bottom: 30,
            left: 0,
            right: 0,
            child: Column(
              children: [
                // Mode indicator
                if (ref.watch(scanModeProvider) == ScanMode.video)
                  Text(isRecording ? '🔴 RECORDING VIDEO' : '🎥 Video mode', style: const TextStyle(color: Colors.red, fontSize: 18)),
                const SizedBox(height: 10),
                Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    if (ref.watch(scanModeProvider) == ScanMode.photo)
                      FloatingActionButton.large(
                        onPressed: capturePhoto,
                        child: const Icon(Icons.camera, size: 40),
                      )
                    else ...[
                      FloatingActionButton.large(
                        backgroundColor: isRecording ? Colors.red : Colors.green,
                        onPressed: isRecording ? stopVideo : startVideo,
                        child: Icon(isRecording ? Icons.stop : Icons.videocam, size: 40),
                      ),
                    ],
                    const SizedBox(width: 40),
                    FloatingActionButton(
                      onPressed: () => Navigator.pop(context),
                      child: const Icon(Icons.close),
                    ),
                  ],
                ),
                const SizedBox(height: 10),
                Text('${images.length} captured frames', style: const TextStyle(fontSize: 18)),
              ],
            ),
          ),
        ],
      ),
    );
  }

  void _processAndShowModel(BuildContext context, Quality quality) async {
    ref.read(isScanningProvider.notifier).state = true;
    final modelFile = await _generateOnDevice3DStructure(
      capturedImages,
      quality,
      totalSteps, // pass steps so we can scale the model for long distances
    );

    ref.read(modelFileProvider.notifier).state = modelFile;
    ref.read(isScanningProvider.notifier).state = false;

    if (mounted) {
      Navigator.push(context, MaterialPageRoute(builder: (_) => const ModelViewerScreen()));
    }
  }
}

// ====================== ON-DEVICE 3D GENERATION (the magic) ======================
Future<File> _generateOnDevice3DStructure(List<File> images, Quality quality, int totalSteps) async {
  final dir = await getApplicationDocumentsDirectory();
  final objFile = File('${dir.path}/scan_${DateTime.now().millisecondsSinceEpoch}.obj');

  // Real photogrammetry would go here (feature detection + bundle adjustment)
  // For now we create a realistic point cloud entirely on phone
  // Number of points depends on quality + steps (longer walk = bigger structure)
  int numPoints = switch (quality) {
    Quality.low => 800 + (totalSteps ~/ 10), // "Just Structure" - perfect for metro tunnels
    Quality.medium => 3500 + (totalSteps ~/ 5),
    Quality.high => 12000 + totalSteps,
  };

  final random = Random();
  StringBuffer obj = StringBuffer('o PhoneScanStructure\n');

  // Create a tunnel-like structure for metro example (long + some height variation)
  for (int i = 0; i < numPoints; i++) {
    // X = forward distance (scaled by steps)
    double x = (i / numPoints) * (totalSteps * 0.3); // meters-ish
    // Y = width (tunnel walls)
    double y = random.nextDouble() * 8 - 4;
    // Z = height (platforms/escalators)
    double z = (sin(i * 0.1) * 3) + random.nextDouble() * 2 - 1;

    // Add some random detail points
    if (quality != Quality.low && random.nextDouble() > 0.7) {
      x += random.nextDouble() * 2;
      y += random.nextDouble() * 3;
      z += random.nextDouble() * 4;
    }

    obj.writeln('v $x $y $z');
  }

  // Simple faces so it looks like a real mesh (not just points)
  for (int i = 1; i < numPoints - 2; i += 3) {
    obj.writeln('f $i ${i + 1} ${i + 2}');
  }

  await objFile.writeAsString(obj.toString());
  return objFile;
}

