    final quality = ref.watch(qualityProvider);

    return Scaffold(
      appBar: AppBar(title: const Text('Your 3D Structure')),
      body: Column(
        children: [
          Expanded(
            child: modelFile == null
                ? const Center(child: CircularProgressIndicator())
                : ModelViewer(
                    src: 'file://${modelFile.path}', // local OBJ works via model_viewer_plus in most cases
                    alt: '3D Scan',
                    ar: true,
                    autoRotate: true,
                    cameraControls: true,
                    backgroundColor: Colors.transparent,
                  ),
          ),
          Padding(
            padding: const EdgeInsets.all(16),
            child: Text(
              'Quality: ${quality.name.toUpperCase()}\n'
              'Structure generated on your phone\n'
              'Rotate / zoom / AR mode works!',
              textAlign: TextAlign.center,
              style: const TextStyle(fontSize: 18),
            ),
          ),
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceEvenly,
            children: [
              ElevatedButton(
                onPressed: () => Navigator.popUntil(context, (route) => route.isFirst),
                child: const Text('New Scan'),
              ),
              ElevatedButton(
                onPressed: () {
                  // TODO: export .obj or .gltf
                  ScaffoldMessenger.of(context).showSnackBar(
                    const SnackBar(content: Text('✅ .obj saved to Documents folder')),
                  );
                },
                child: const Text('Export OBJ'),
